# Ignore operating system files
.DS_Store
Thumbs.db

# Ignore Python virtual environments
venv/
virtualenv/
env/
venv3/
.venv/

# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore IDE/editor configuration files
.vscode/
.idea/
*.swp
*.swo

# Ignore build artifacts and distribution files
dist/
build/
*.egg-info/

# Ignore testing artifacts
.pytest_cache/
htmlcov/
coverage/

# Ignore log files
*.log

# Ignore secrets and environment files (if any)
.env
*.env
*.env.*.local

# Ignore temporary files
*.tmp
*.temp

# Ignore package manager lock files (if any, though unlikely for pure filter lists)
# Pipfile.lock
# poetry.lock

# Ignore specific files generated by filter list tools if any
# (Add any known tool-specific ignore patterns here)
